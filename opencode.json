{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5",
  "default_agent": "build",
  "instructions": ["AGENTS.md"],
  "permission": {
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git worktree*": "allow",
      "ls*": "allow",
      "find*": "allow",
      "grep*": "allow",
      "rg*": "allow",
      "cat*": "allow",
      "sed*": "allow",
      "awk*": "allow"
    }
  },
  "agent": {
    "build": {
      "description": "Team lead for brainstorming, synthesis, and review-pack production.",
      "prompt": "{file:./prompts/lead.txt}",
      "steps": 20,
      "permission": {
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git branch*": "allow",
          "git worktree*": "allow",
          "git add*": "ask",
          "git commit*": "deny",
          "git push*": "deny",
          "kubectl*": "ask",
          "oc*": "ask",
          "ansible*": "ask",
          "ansible-playbook*": "ask",
          "helm*": "ask",
          "kustomize*": "ask",
          "make*": "ask",
          "pytest*": "ask",
          "go test*": "ask",
          "mvn*": "ask",
          "gradle*": "ask",
          "npm*": "ask",
          "pnpm*": "ask",
          "yarn*": "ask"
        }
      }
    },
    "plan": {
      "description": "Read-only architect for options, trade-offs, and design convergence.",
      "prompt": "{file:./prompts/planner.txt}",
      "steps": 12,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "patch": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "ls*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "cat*": "allow",
          "sed*": "allow",
          "awk*": "allow"
        }
      }
    },
    "reviewer": {
      "description": "Strict reviewer for assumptions, risk, clarity, and review readiness.",
      "prompt": "{file:./prompts/reviewer.txt}",
      "steps": 12,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "patch": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "cat*": "allow"
        }
      }
