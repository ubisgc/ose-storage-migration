    "tester": {
      "description": "Validation thinker for design-stage checks, proofs, and acceptance concepts.",
      "prompt": "{file:./prompts/tester.txt}",
      "steps": 14,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "patch": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "cat*": "allow",
          "kubectl*": "ask",
          "oc*": "ask"
