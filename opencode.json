    "platform-expert": {
      "description": "Kubernetes, OpenShift, Linux, storage, and Ansible specialist for design exploration.",
      "prompt": "{file:./prompts/platform-expert.txt}",
      "steps": 18,
      "permission": {
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "cat*": "allow",
          "kubectl*": "ask",
          "oc*": "ask",
          "helm*": "ask",
          "kustomize*": "ask",
          "ansible*": "ask",
          "ansible-playbook*": "ask",
          "systemctl*": "ask",
          "journalctl*": "ask",
          "ss*": "ask",
          "ip*": "ask",
          "mount*": "ask",
          "df*": "ask",
          "du*": "ask"
        }
      }
    },
    "explore": {
      "description": "Repository and environment mapper that gathers only enough context to inform brainstorming and design.",
      "prompt": "{file:./prompts/explorer.txt}",
      "steps": 10,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "patch": "deny",
        "bash": {
          "*": "ask",
          "ls*": "allow",
          "find*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "cat*": "allow",
          "sed*": "allow",
          "awk*": "allow",
          "git status*": "allow",
          "git diff*": "allow"
        }
      }
